# JCBMS backend local environment template.
# Copy this file to .env and adjust values for your machine or deployment.

JCBMS_PROFILE=./uploadPath

JCBMS_LOG_LEVEL=debug
JCBMS_SPRING_LOG_LEVEL=warn

JCBMS_REDIS_HOST=localhost
JCBMS_REDIS_PORT=6379
JCBMS_REDIS_DATABASE=0
JCBMS_REDIS_PASSWORD=

JCBMS_TOKEN_SECRET=dev-only-jcbms-token-secret
JCBMS_SWAGGER_ENABLED=true

JCBMS_DB_URL=jdbc:mysql://localhost:3306/jcbms?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
JCBMS_DB_USERNAME=root
JCBMS_DB_PASSWORD=123456

JCBMS_SLAVE_DB_ENABLED=false
JCBMS_SLAVE_DB_URL=
JCBMS_SLAVE_DB_USERNAME=
JCBMS_SLAVE_DB_PASSWORD=

JCBMS_DRUID_ENABLED=false
JCBMS_DRUID_ALLOW=127.0.0.1
JCBMS_DRUID_USERNAME=admin
JCBMS_DRUID_PASSWORD=123456
